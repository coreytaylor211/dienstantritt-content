    {
      "anchorSearchTitle": "Abkürzungs-Lexikon",
      "id": "12.5",
      "items": [
        {
          "abbr": "GA",
          "id": "12.5-abbreviations-ga",
          "meaning": [
            {
              "text": "Grundausbildung — Erste rund drei Monate der militärischen Ausbildung; vermittelt soldatische Grundfertigkeiten (siehe Modul 2). Bis Ende 2011 „AGA\"."
            }
          ]
        },
        {
          "abbr": "AGA",
          "id": "12.5-abbreviations-aga",
          "meaning": [
            {
              "text": "Allgemeine Grundausbildung — Frühere (bis Ende 2011) Bezeichnung der Grundausbildung; umgangssprachlich weiter gebräuchlich (siehe Modul 2)."
            }
          ]
        },
        {
          "abbr": "FWDL",
          "id": "12.5-abbreviations-fwdl",
          "meaning": [
            {
              "text": "Freiwillig Wehrdienstleistende:r — Status bei 6–11 Monaten Dienst im Neuen Wehrdienst."
            }
          ]
        },
        {
          "abbr": "SaZ",
          "id": "12.5-abbreviations-saz",
          "meaning": [
            {
              "text": "Soldat:in auf Zeit — Status ab 12 Monaten Verpflichtung; im Neuen Wehrdienst auf min. 12 Monate gesenkt (z. B. SaZ 4 = 4 Jahre)."
            }
          ]
        },
        {
          "abbr": "BS",
          "id": "12.5-abbreviations-bs",
          "meaning": [
            {
              "text": "Berufssoldat:in — Soldat:in mit Verpflichtung bis zur Altersgrenze (Laufbahn auf Lebenszeit)."
            }
          ]
        },
        {
          "abbr": "BFT",
          "id": "12.5-abbreviations-bft",
          "meaning": [
            {
              "text": "Basis-Fitness-Test — Test der körperlichen Grundfitness (Sprint, Klimmhang, 1.000-m-Lauf)."
            }
          ]
        },
        {
          "abbr": "BMVg",
          "id": "12.5-abbreviations-bmvg",
          "meaning": [
            {
              "text": "Bundesministerium der Verteidigung — Das Verteidigungsministerium."
            }
          ]
        },
        {
          "abbr": "Bw",
          "id": "12.5-abbreviations-bw",
          "meaning": [
            {
              "text": "Bundeswehr — Die Streitkräfte Deutschlands."
            }
          ]
        },
        {
          "abbr": "TSK",
          "id": "12.5-abbreviations-tsk",
          "meaning": [
            {
              "text": "Teilstreitkraft — z. B. Heer, Luftwaffe, Marine."
            }
          ]
        },
        {
          "abbr": "UvD",
          "id": "12.5-abbreviations-uvd",
          "meaning": [
            {
              "text": "Unteroffizier vom Dienst — Diensthabende:r Unteroffizier:in mit Aufsichts- und Ordnungsaufgaben in der Einheit (Dienstposten im Innendienst)."
            }
          ]
        },
        {
          "abbr": "GvD",
          "id": "12.5-abbreviations-gvd",
          "meaning": [
            {
              "text": "Gefreiter vom Dienst — Diensthabende:r Mannschaftssoldat:in zur Unterstützung des UvD."
            }
          ]
        },
        {
          "abbr": "OvWa",
          "id": "12.5-abbreviations-ovwa",
          "meaning": [
            {
              "text": "Offizier vom Wachdienst — Wachvorgesetzte:r, verantwortlich für Sicherung und Disziplin der Wache."
            }
          ]
        },
        {
          "abbr": "KpFw",
          "id": "12.5-abbreviations-kpfw",
          "meaning": [
            {
              "text": "Kompaniefeldwebel — „Spieß\"; verantwortlich für innere Organisation, Personal und Versorgung der Kompanie (siehe Slang/Spieß unten)."
            }
          ]
        },
        {
          "abbr": "StOFw",
          "id": "12.5-abbreviations-stofw",
          "meaning": [
            {
              "text": "Standortfeldwebel — Feldwebel mit standortbezogenen Verwaltungs-/Organisationsaufgaben."
            }
          ]
        },
        {
          "abbr": "Uffz",
          "id": "12.5-abbreviations-uffz",
          "meaning": [
            {
              "text": "Unteroffizier — Dienstgradgruppe der Unteroffiziere."
            }
          ]
        },
        {
          "abbr": "Fw",
          "id": "12.5-abbreviations-fw",
          "meaning": [
            {
              "text": "Feldwebel — Dienstgrad bzw. -gruppe der Feldwebel."
            }
          ]
        },
        {
          "abbr": "Lt",
          "id": "12.5-abbreviations-lt",
          "meaning": [
            {
              "text": "Leutnant — Erster Offiziersdienstgrad."
            }
          ]
        },
        {
          "abbr": "DV",
          "id": "12.5-abbreviations-dv",
          "meaning": [
            {
              "text": "Dienstvorschrift — Verbindliche Regelung/Anweisung der Bundeswehr."
            }
          ]
        },
        {
          "abbr": "ZDv",
          "id": "12.5-abbreviations-zdv",
          "meaning": [
            {
              "text": "Zentrale Dienstvorschrift — Verbindliche Vorschrift der Bundeswehr (das Vorschriftenwesen wurde teils modernisiert, z. B. „Allgemeine Regelung\"/„Zentralrichtlinie\")."
            }
          ]
        },
        {
          "abbr": "DGA",
          "id": "12.5-abbreviations-dga",
          "meaning": [
            {
              "text": "Dienstgradabzeichen — Kennzeichnet den Dienstgrad an der Uniform (Schulterklappen/-stücke, Ärmel, Aufschiebeschlaufen)."
            }
          ]
        },
        {
          "abbr": "SAZV",
          "id": "12.5-abbreviations-sazv",
          "meaning": [
            {
              "text": "Soldatenarbeitszeitverordnung — Verordnung über die Arbeitszeit der Soldatinnen und Soldaten; gilt für Soldat:innen im Geschäftsbereich des BMVg (Quelle: gesetze-im-internet.de, SAZV, abgerufen 2026-06-01)."
            }
          ]
        },
        {
          "abbr": "SG",
          "id": "12.5-abbreviations-sg",
          "meaning": [
            {
              "text": "Soldatengesetz — Gesetz über die Rechtsstellung der Soldat:innen (Pflichten und Rechte)."
            }
          ]
        },
        {
          "abbr": "WDO",
          "id": "12.5-abbreviations-wdo",
          "meaning": [
            {
              "text": "Wehrdisziplinarordnung — Regelt Anerkennung besonderer Leistungen und Ahndung von Dienstvergehen."
            }
          ]
        },
        {
          "abbr": "WBO",
          "id": "12.5-abbreviations-wbo",
          "meaning": [
            {
              "text": "Wehrbeschwerdeordnung — Regelt das Beschwerderecht der Soldat:innen."
            }
          ]
        },
        {
          "abbr": "SBG",
          "id": "12.5-abbreviations-sbg",
          "meaning": [
            {
              "text": "Soldatinnen- und Soldatenbeteiligungsgesetz — Regelt Beteiligungsrechte (Vertrauenspersonen, Mitbestimmung)."
            }
          ]
        },
        {
          "abbr": "InFü",
          "id": "12.5-abbreviations-infue",
          "meaning": [
            {
              "text": "Innere Führung — Führungsphilosophie/Leitbild „Staatsbürger:in in Uniform\"."
            }
          ]
        },
        {
          "abbr": "UZwGBw",
          "id": "12.5-abbreviations-uzwgbw",
          "meaning": [
            {
              "text": "Gesetz über die Anwendung unmittelbaren Zwanges durch Soldaten der Bundeswehr — Rechtsgrundlage für Wach-/Sicherungsaufgaben."
            }
          ]
        },
        {
          "abbr": "WBK",
          "id": "12.5-abbreviations-wbk",
          "meaning": [
            {
              "text": "Waffenbesitzkarte — Erlaubnis zum Besitz erlaubnispflichtiger Schusswaffen und Munition."
            }
          ]
        },
        {
          "abbr": "San",
          "id": "12.5-abbreviations-san",
          "meaning": [
            {
              "text": "Sanitäter:in / Sanitätsdienst — Medizinisches Personal bzw. Sanitätsbereich; auch als Vorsilbe (z. B. SanDstBw)."
            }
          ]
        },
        {
          "abbr": "ABC",
          "id": "12.5-abbreviations-abc",
          "meaning": [
            {
              "text": "Atomar, Biologisch, Chemisch — Bezeichnung für entsprechende Gefahren/Schutz (ABC-Schutz)."
            }
          ]
        },
        {
          "abbr": "EH",
          "id": "12.5-abbreviations-eh",
          "meaning": [
            {
              "text": "Erste Hilfe — Sofortmaßnahmen bei Verletzung/Notfall."
            }
          ]
        },
        {
          "abbr": "EPa",
          "id": "12.5-abbreviations-epa",
          "meaning": [
            {
              "text": "Einmannpackung — Verpflegungspaket für eine:n Soldat:in (z. B. im Feld)."
            }
          ]
        },
        {
          "abbr": "MG",
          "id": "12.5-abbreviations-mg",
          "meaning": [
            {
              "text": "Maschinengewehr — Automatische Unterstützungswaffe."
            }
          ]
        },
        {
          "abbr": "Btl",
          "id": "12.5-abbreviations-btl",
          "meaning": [
            {
              "text": "Bataillon — Truppenverband aus mehreren Kompanien."
            }
          ]
        },
        {
          "abbr": "Kp",
          "id": "12.5-abbreviations-kp",
          "meaning": [
            {
              "text": "Kompanie — Truppeneinheit aus mehreren Zügen; deine „Heimat\" in der Grundausbildung."
            }
          ]
        },
        {
          "abbr": "Zg",
          "id": "12.5-abbreviations-zg",
          "meaning": [
            {
              "text": "Zug — Untereinheit der Kompanie, mehrere Gruppen."
            }
          ]
        },
        {
          "abbr": "Gru",
          "id": "12.5-abbreviations-gru",
          "meaning": [
            {
              "text": "Gruppe — Kleinste Gliederungseinheit."
            }
          ]
        },
        {
          "abbr": "DZE",
          "id": "12.5-abbreviations-dze",
          "meaning": [
            {
              "text": "Dienstzeitende — Ende der Dienstzeit/des Wehrdienstverhältnisses."
            }
          ]
        },
        {
          "abbr": "DU",
          "id": "12.5-abbreviations-du",
          "meaning": [
            {
              "text": "Dienstunfähigkeit / Direktunterstützung — Mehrdeutig: meist „Dienstunfähigkeit\" (gesundheitlich, vorübergehend), in der Logistik auch „Direktunterstützung\". Welche Lesart gemeint ist, ergibt sich aus dem Zusammenhang – frag im Zweifel nach."
            }
          ]
        }
      ],
      "title": "Abkürzungs-Lexikon",
      "type": "abbreviations"
    },
