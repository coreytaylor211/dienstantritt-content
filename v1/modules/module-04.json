              "type": "paragraph"
            },
            {
              "items": [
                [
                  {
                    "bold": true,
                    "text": "Klasse B (Pkw):"
                  },
                  {
                    "text": " bis zu "
                  },
                  {
                    "bold": true,
                    "text": "3.500 €"
                  },
                  {
                    "text": "."
                  }
                ],
                [
                  {
                    "bold": true,
                    "text": "Klasse C/C1 (Lkw):"
                  },
                  {
                    "text": " bis zu "
                  },
                  {
                    "bold": true,
                    "text": "5.000 €"
                  },
                  {
                    "text": "."
                  }
                ]
              ],
              "ordered": false,
              "type": "list"
            },
            {
              "spans": [
                {
                  "text": "Wichtige Bedingungen (Stand 2026):"
                }
              ],
              "type": "paragraph"
            },
            {
              "items": [
                [
                  {
                    "text": "Pkw-Erwerb: 12 Monate vor Dienstbeginn bis 12 Monate nach Dienstende; Lkw: bis 36 Monate nach Dienstende."
                  }
                ],
                [
                  {
                    "text": "Dienst nach dem 01.01.2026 begonnen, Führerschein nach dem 01.01.2025 erworben."
                  }
                ],
                [
                  {
                    "text": "Antrag frühestens ab 01.01.2027, spätestens 12 Monate nach Erfüllen aller Voraussetzungen."
